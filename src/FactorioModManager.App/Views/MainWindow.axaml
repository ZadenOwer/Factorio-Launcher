<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FactorioModManager.App.Views.MainWindow"
        Title="Factorio Launcher"
        Width="1280"
        Height="820"
        MinWidth="980"
        MinHeight="620"
        Background="#1A1814"
        FontFamily="Inter, Segoe UI, Arial">
  <Window.Styles>
    <Style Selector="TextBlock">
      <Setter Property="Foreground" Value="#E8DFCF" />
      <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="TextBlock.muted">
      <Setter Property="Foreground" Value="#8A7D65" />
      <Setter Property="FontSize" Value="12" />
    </Style>
    <Style Selector="TextBlock.dim">
      <Setter Property="Foreground" Value="#6A604F" />
      <Setter Property="FontSize" Value="11" />
    </Style>
    <Style Selector="TextBlock.mono">
      <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, monospace" />
      <Setter Property="Foreground" Value="#A89C84" />
      <Setter Property="FontSize" Value="11" />
    </Style>
    <Style Selector="TextBlock.header">
      <Setter Property="Foreground" Value="#6A604F" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button">
      <Setter Property="MinHeight" Value="30" />
      <Setter Property="Padding" Value="11,5" />
      <Setter Property="CornerRadius" Value="5" />
      <Setter Property="Background" Value="#221D18" />
      <Setter Property="Foreground" Value="#E8DFCF" />
      <Setter Property="BorderBrush" Value="#3A342C" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="Medium" />
    </Style>
    <Style Selector="Button:disabled">
      <Setter Property="Opacity" Value="0.5" />
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="#D97A2C" />
      <Setter Property="BorderBrush" Value="#F0A455" />
      <Setter Property="Foreground" Value="#1A1814" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.danger">
      <Setter Property="Background" Value="#2A1510" />
      <Setter Property="BorderBrush" Value="#5A2820" />
      <Setter Property="Foreground" Value="#E89089" />
    </Style>
    <Style Selector="Button.tab">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="#8A7D65" />
      <Setter Property="Padding" Value="12,5" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="CornerRadius" Value="0" />
    </Style>
    <Style Selector="Button.tabActive">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="#F0A455" />
      <Setter Property="BorderThickness" Value="0,0,0,2" />
      <Setter Property="Foreground" Value="#F0A455" />
      <Setter Property="Padding" Value="12,5" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="CornerRadius" Value="0" />
    </Style>
    <Style Selector="Button.path">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="Foreground" Value="#A89C84" />
      <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, monospace" />
      <Setter Property="FontSize" Value="11" />
    </Style>
    <Style Selector="TextBox">
      <Setter Property="MinHeight" Value="31" />
      <Setter Property="CornerRadius" Value="5" />
      <Setter Property="Background" Value="#15110D" />
      <Setter Property="Foreground" Value="#E8DFCF" />
      <Setter Property="BorderBrush" Value="#3A342C" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="9,5" />
      <Setter Property="FontSize" Value="12" />
    </Style>
    <Style Selector="ComboBox">
      <Setter Property="MinHeight" Value="24" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Background" Value="#221D18" />
      <Setter Property="Foreground" Value="#E8DFCF" />
      <Setter Property="BorderBrush" Value="#3A342C" />
      <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, monospace" />
      <Setter Property="FontSize" Value="11" />
    </Style>
    <Style Selector="CheckBox /template/ Border">
      <Setter Property="Background" Value="#15110D" />
      <Setter Property="BorderBrush" Value="#3A342C" />
      <Setter Property="CornerRadius" Value="3" />
    </Style>
    <Style Selector="CheckBox:checked /template/ Border">
      <Setter Property="Background" Value="#D97A2C" />
      <Setter Property="BorderBrush" Value="#D97A2C" />
    </Style>
    <Style Selector="Border.row">
      <Setter Property="BorderBrush" Value="#221D18" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="Padding" Value="18,8" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
    <Style Selector="Border.selectedRow">
      <Setter Property="Background" Value="#221D18" />
      <Setter Property="BorderBrush" Value="#221D18" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="Padding" Value="18,8" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
    <Style Selector="ListBox">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="ListBoxItem">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,0,0,1" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>
    <Style Selector="ListBoxItem /template/ ContentPresenter">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
      <Setter Property="Background" Value="#221D18" />
    </Style>
    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#221D18" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="48,*">
    <Border Grid.Row="0" Background="#15110D" BorderBrush="#221D18" BorderThickness="0,0,0,1" Padding="14,8">
      <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto" ColumnSpacing="12" VerticalAlignment="Center">
        <Border Width="24" Height="24" CornerRadius="4" Background="#D97A2C" BorderBrush="#B86620" BorderThickness="1">
          <TextBlock Text="F" Foreground="#1A0E05" FontWeight="Bold" FontFamily="Consolas, Cascadia Mono, monospace" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
        <TextBlock Grid.Column="1" Text="Factorio Launcher" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" />
        <TextBlock Grid.Column="2" Text="/" Classes="dim" VerticalAlignment="Center" />
        <Button Grid.Column="3" Classes="path" Command="{Binding BrowseFolderCommand}" VerticalAlignment="Center">
          <TextBlock Text="{Binding FolderPathCompact}" Classes="mono" TextTrimming="CharacterEllipsis" MaxWidth="360" />
        </Button>

        <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="0" VerticalAlignment="Center">
          <Button Classes="tabActive" Command="{Binding ShowListsCommand}" IsVisible="{Binding IsListsTabActive}">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="Lists" Foreground="#F0A455" FontWeight="Medium" />
              <Border Background="#221D18" CornerRadius="3" Padding="5,1">
                <TextBlock Text="{Binding ModListCount}" Classes="dim" FontSize="10" />
              </Border>
            </StackPanel>
          </Button>
          <Button Classes="tab" Command="{Binding ShowListsCommand}" IsVisible="{Binding IsListsTabInactive}">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="Lists" Foreground="#8A7D65" FontWeight="Medium" />
              <Border Background="#221D18" CornerRadius="3" Padding="5,1">
                <TextBlock Text="{Binding ModListCount}" Classes="dim" FontSize="10" />
              </Border>
            </StackPanel>
          </Button>
          <Button Classes="tabActive" Command="{Binding ShowModsCommand}" IsVisible="{Binding IsModsTabActive}">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="Mods" Foreground="#F0A455" FontWeight="Medium" />
              <Border Background="#221D18" CornerRadius="3" Padding="5,1">
                <TextBlock Text="{Binding AvailableModCount}" Classes="dim" FontSize="10" />
              </Border>
            </StackPanel>
          </Button>
          <Button Classes="tab" Command="{Binding ShowModsCommand}" IsVisible="{Binding IsModsTabInactive}">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="Mods" Foreground="#8A7D65" FontWeight="Medium" />
              <Border Background="#221D18" CornerRadius="3" Padding="5,1">
                <TextBlock Text="{Binding AvailableModCount}" Classes="dim" FontSize="10" />
              </Border>
            </StackPanel>
          </Button>
        </StackPanel>

        <Border Grid.Column="6" Background="#15201A" BorderBrush="#2A4A30" BorderThickness="1" CornerRadius="5" Padding="9,4" IsVisible="{Binding HasActiveList}">
          <StackPanel Orientation="Horizontal" Spacing="7">
            <Ellipse Width="7" Height="7" Fill="#5FA84A" VerticalAlignment="Center" />
            <TextBlock Text="{Binding ActiveListName}" Foreground="#5FA84A" FontWeight="SemiBold" FontSize="12" />
          </StackPanel>
        </Border>
      </Grid>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="270,*">
      <Border Grid.Column="0" BorderBrush="#221D18" BorderThickness="0,0,1,0">
        <Grid RowDefinitions="Auto,*" Background="#1A1814">
          <StackPanel Grid.Row="0" Margin="12,10,12,8" Spacing="8">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="7">
              <TextBox Watermark="Filter..." Text="{Binding ListSearchText, Mode=TwoWay}" />
              <Button Grid.Column="1" Classes="primary" Content="+ New" Command="{Binding CreateModListCommand}" />
            </Grid>
            <TextBlock Classes="header" Text="{Binding VisibleModListCount, StringFormat='MOD LISTS - {0}'}" />
          </StackPanel>

          <ListBox Grid.Row="1"
                   ItemsSource="{Binding ModLists}"
                   SelectedItem="{Binding SelectedModList}"
                   Padding="6,0,6,8">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border Padding="8,7" CornerRadius="4">
                  <Grid ColumnDefinitions="2,*" ColumnSpacing="6">
                    <Border Width="2" CornerRadius="1" Background="#5FA84A" IsVisible="{Binding IsActive}" />
                    <Grid Grid.Column="1" RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="2">
                      <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <Ellipse Width="5" Height="5" Fill="#5FA84A" IsVisible="{Binding IsActive}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ModCount}" Classes="mono" />
                      </StackPanel>
                      <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding Description}" Classes="dim" TextTrimming="CharacterEllipsis" />
                    </Grid>
                  </Grid>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>

      <Grid Grid.Column="1" Background="#1A1814">
        <Grid IsVisible="{Binding IsListsTabActive}" RowDefinitions="Auto,Auto,Auto,*">
          <Border Grid.Row="0" BorderBrush="#221D18" BorderThickness="0,0,0,1" Padding="18,12">
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="7" ColumnSpacing="12">
              <StackPanel Grid.RowSpan="3" IsVisible="{Binding IsNormalMode}" Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="{Binding SelectedListName}" FontSize="18" FontWeight="SemiBold" />
                  <Border Background="#15201A" BorderBrush="#2A4A30" BorderThickness="1" CornerRadius="4" Padding="7,2" IsVisible="{Binding SelectedModList.IsActive}">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                      <Ellipse Width="5" Height="5" Fill="#5FA84A" VerticalAlignment="Center" />
                      <TextBlock Text="ACTIVE" Foreground="#5FA84A" FontWeight="SemiBold" FontSize="10" />
                    </StackPanel>
                  </Border>
                </StackPanel>
                <TextBlock Text="{Binding SelectedListDescription}" Classes="muted" />
                <TextBlock Text="{Binding SelectedListSummary}" Classes="dim" />
              </StackPanel>

              <TextBox IsVisible="{Binding IsEditMode}"
                       Text="{Binding DraftName, Mode=TwoWay}"
                       FontSize="17"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Stretch" />
              <TextBox Grid.Row="1"
                       Grid.ColumnSpan="2"
                       IsVisible="{Binding IsEditMode}"
                       Text="{Binding DraftDescription, Mode=TwoWay}"
                       Watermark="Description (optional)"
                       HorizontalAlignment="Stretch" />
              <TextBlock Grid.Row="2"
                         Grid.ColumnSpan="2"
                         IsVisible="{Binding IsEditMode}"
                         Text="{Binding DraftSummaryLabel}"
                         Classes="dim" />

              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="7" VerticalAlignment="Top">
                <StackPanel Orientation="Horizontal" Spacing="7" IsVisible="{Binding IsNormalMode}">
                  <Button Content="Cancel" Command="{Binding EditSelectedCommand}" />
                  <Button Classes="danger" Content="Delete" Command="{Binding DeleteSelectedCommand}" />
                  <Button Classes="primary" Content="Activate" Command="{Binding ActivateSelectedCommand}" IsEnabled="{Binding CanActivateSelected}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="7" IsVisible="{Binding IsEditMode}">
                  <Button Content="Cancel" Command="{Binding CancelEditCommand}" />
                  <Button Classes="primary" Content="Save" Command="{Binding SaveEditCommand}" />
                </StackPanel>
              </StackPanel>
            </Grid>
          </Border>

          <Border Grid.Row="1" BorderBrush="#221D18" BorderThickness="0,1,0,1" Padding="18,8" IsVisible="{Binding IsEditMode}">
            <TextBox Watermark="Search mods..." Text="{Binding SearchText, Mode=TwoWay}" />
          </Border>

          <Border Grid.Row="2" BorderBrush="#221D18" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,90,120" Margin="18,7" ColumnSpacing="12">
              <TextBlock Classes="header" Text="" />
              <TextBlock Grid.Column="1" Classes="header" Text="SIZE" />
              <TextBlock Grid.Column="2" Classes="header" Text="VERSION" />
            </Grid>
          </Border>

          <Grid Grid.Row="3">
            <ListBox IsVisible="{Binding IsNormalMode}" ItemsSource="{Binding SelectedMods}" BorderThickness="0" Background="Transparent">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Border Classes="row">
                    <Grid ColumnDefinitions="*,90,120" ColumnSpacing="12" VerticalAlignment="Center" HorizontalAlignment="Stretch">
                      <Grid RowDefinitions="Auto,Auto" ClipToBounds="True" HorizontalAlignment="Stretch">
                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Row="1" Text="{Binding Subtitle}" Classes="muted" TextTrimming="CharacterEllipsis" />
                      </Grid>
                      <TextBlock Grid.Column="1" Text="{Binding Size}" Classes="mono" VerticalAlignment="Center" />
                      <Border Grid.Column="2" Background="#221D18" BorderBrush="#3A342C" BorderThickness="1" CornerRadius="4" Padding="7,3" HorizontalAlignment="Left">
                        <TextBlock Text="{Binding DisplayVersion}" Classes="mono" />
                      </Border>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>

            <ListBox IsVisible="{Binding IsEditMode}" ItemsSource="{Binding EditableMods}" BorderThickness="0" Background="Transparent">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Border Classes="row" Background="{Binding RowBackground}">
                    <Grid ColumnDefinitions="32,*,90,130" ColumnSpacing="12" VerticalAlignment="Center" HorizontalAlignment="Stretch">
                      <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center" />
                      <Grid Grid.Column="1" RowDefinitions="Auto,Auto" ClipToBounds="True" HorizontalAlignment="Stretch">
                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Row="1" Text="{Binding Subtitle}" Classes="muted" TextTrimming="CharacterEllipsis" />
                      </Grid>
                      <TextBlock Grid.Column="2" Text="{Binding Size}" Classes="mono" VerticalAlignment="Center" />
                      <ComboBox Grid.Column="3"
                                ItemsSource="{Binding AvailableVersions}"
                                SelectedItem="{Binding SelectedVersion}"
                                IsEnabled="{Binding IsSelected}" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Grid>
        </Grid>

        <Grid IsVisible="{Binding IsModsTabActive}" RowDefinitions="Auto,Auto,*">
          <StackPanel Grid.Row="0" Margin="18,14" Spacing="4">
            <TextBlock Text="Installed Mods" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Text="{Binding AvailableModCount, StringFormat='{}{0} root mods detected. Zip files are read-only.'}" Classes="muted" />
          </StackPanel>
          <Border Grid.Row="1" BorderBrush="#221D18" BorderThickness="0,1,0,1">
            <Grid ColumnDefinitions="*,90,130" Margin="18,7" ColumnSpacing="12">
              <TextBlock Classes="header" Text="" />
              <TextBlock Grid.Column="1" Classes="header" Text="SIZE" />
              <TextBlock Grid.Column="2" Classes="header" Text="VERSIONS" />
            </Grid>
          </Border>
          <ListBox Grid.Row="2" ItemsSource="{Binding InstalledMods}" BorderThickness="0" Background="Transparent">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border Classes="row">
                  <Grid ColumnDefinitions="*,90,130" ColumnSpacing="12" VerticalAlignment="Center" HorizontalAlignment="Stretch">
                    <Grid RowDefinitions="Auto,Auto" ClipToBounds="True" HorizontalAlignment="Stretch">
                      <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                      <TextBlock Grid.Row="1" Text="{Binding Subtitle}" Classes="muted" TextTrimming="CharacterEllipsis" />
                    </Grid>
                    <TextBlock Grid.Column="1" Text="{Binding Size}" Classes="mono" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="2" Spacing="1">
                      <TextBlock Text="{Binding VersionCount}" Classes="mono" />
                      <TextBlock Text="{Binding Versions}" Classes="dim" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                  </Grid>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>

        <Border Background="#2A1510" BorderBrush="#5A2820" BorderThickness="1" CornerRadius="5" Padding="10" Margin="18" VerticalAlignment="Bottom" IsVisible="{Binding HasError}">
          <TextBlock Text="{Binding ErrorMessage}" Foreground="#E89089" TextWrapping="Wrap" />
        </Border>
      </Grid>
    </Grid>
  </Grid>
</Window>
