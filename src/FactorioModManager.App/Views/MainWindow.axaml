<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FactorioModManager.App.Views.MainWindow"
        Title="Factorio Launcher"
        Width="1280"
        Height="820"
        MinWidth="980"
        MinHeight="620"
        Background="#1A1814"
        FontFamily="Inter, Segoe UI, Arial"
		Icon="avares://FactorioModManager.App/Assets/icon.ico">
  <Window.Styles>
    <Style Selector="TextBlock">
      <Setter Property="Foreground" Value="#E8DFCF" />
      <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="TextBlock.muted">
      <Setter Property="Foreground" Value="#8A7D65" />
      <Setter Property="FontSize" Value="12" />
    </Style>
    <Style Selector="TextBlock.dim">
      <Setter Property="Foreground" Value="#6A604F" />
      <Setter Property="FontSize" Value="11" />
    </Style>
    <Style Selector="TextBlock.mono">
      <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, monospace" />
      <Setter Property="Foreground" Value="#A89C84" />
      <Setter Property="FontSize" Value="11" />
    </Style>
    <Style Selector="TextBlock.header">
      <Setter Property="Foreground" Value="#6A604F" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.headerSort">
      <Setter Property="MinHeight" Value="22" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="CornerRadius" Value="3" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#6A604F" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
    </Style>
    <Style Selector="Button.headerSort:pointerover">
      <Setter Property="Background" Value="#221D18" />
      <Setter Property="Foreground" Value="#A89C84" />
    </Style>
    <Style Selector="Button.headerSortActive">
      <Setter Property="MinHeight" Value="22" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="CornerRadius" Value="3" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#F0A455" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
    </Style>
    <Style Selector="Button.headerSortActive:pointerover">
      <Setter Property="Background" Value="#221D18" />
      <Setter Property="Foreground" Value="#F0A455" />
    </Style>
    <Style Selector="Button">
      <Setter Property="MinHeight" Value="30" />
      <Setter Property="Padding" Value="11,5" />
      <Setter Property="CornerRadius" Value="5" />
      <Setter Property="Background" Value="#221D18" />
      <Setter Property="Foreground" Value="#E8DFCF" />
      <Setter Property="BorderBrush" Value="#3A342C" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="Medium" />
    </Style>
    <Style Selector="Button:disabled">
      <Setter Property="Opacity" Value="0.5" />
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="#D97A2C" />
      <Setter Property="BorderBrush" Value="#F0A455" />
      <Setter Property="Foreground" Value="#1A1814" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.danger">
      <Setter Property="Background" Value="#2A1510" />
      <Setter Property="BorderBrush" Value="#5A2820" />
      <Setter Property="Foreground" Value="#E89089" />
    </Style>
    <Style Selector="Button.iconButton">
      <Setter Property="Width" Value="30" />
      <Setter Property="Height" Value="30" />
      <Setter Property="MinWidth" Value="30" />
      <Setter Property="MinHeight" Value="28" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="CornerRadius" Value="5" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="#E8DFCF" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.iconButton:pointerover">
      <Setter Property="Background" Value="#221D18" />
    </Style>
    <Style Selector="Button.activeBadge">
      <Setter Property="Background" Value="#15201A" />
      <Setter Property="BorderBrush" Value="#2A4A30" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="5" />
      <Setter Property="Padding" Value="9,4" />
      <Setter Property="MinHeight" Value="0" />
    </Style>
    <Style Selector="Button.activeBadge:pointerover">
      <Setter Property="Background" Value="#1A2A1E" />
      <Setter Property="BorderBrush" Value="#3B6A42" />
    </Style>
    <Style Selector="Button.tab">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="#8A7D65" />
      <Setter Property="Padding" Value="12,5" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="CornerRadius" Value="0" />
    </Style>
    <Style Selector="Button.tabActive">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="#F0A455" />
      <Setter Property="BorderThickness" Value="0,0,0,2" />
      <Setter Property="Foreground" Value="#F0A455" />
      <Setter Property="Padding" Value="12,5" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="CornerRadius" Value="0" />
    </Style>
    <Style Selector="Button.path">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="Foreground" Value="#A89C84" />
      <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, monospace" />
      <Setter Property="FontSize" Value="11" />
    </Style>
    <Style Selector="TextBox">
      <Setter Property="MinHeight" Value="31" />
      <Setter Property="CornerRadius" Value="5" />
      <Setter Property="Background" Value="#15110D" />
      <Setter Property="Foreground" Value="#E8DFCF" />
      <Setter Property="BorderBrush" Value="#3A342C" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="9,5" />
      <Setter Property="FontSize" Value="12" />
    </Style>
    <Style Selector="ComboBox">
      <Setter Property="MinHeight" Value="24" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Background" Value="#221D18" />
      <Setter Property="Foreground" Value="#E8DFCF" />
      <Setter Property="BorderBrush" Value="#3A342C" />
      <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, monospace" />
      <Setter Property="FontSize" Value="11" />
    </Style>
    <Style Selector="ToggleButton.modCheck">
      <Setter Property="Width" Value="18" />
      <Setter Property="Height" Value="18" />
      <Setter Property="MinWidth" Value="18" />
      <Setter Property="MinHeight" Value="18" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="CornerRadius" Value="3" />
      <Setter Property="Background" Value="#15110D" />
      <Setter Property="BorderBrush" Value="#6A604F" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="Transparent" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="ToggleButton.modCheck:pointerover">
      <Setter Property="Background" Value="#221D18" />
      <Setter Property="BorderBrush" Value="#8A7D65" />
    </Style>
    <Style Selector="ToggleButton.modCheck:checked">
      <Setter Property="Background" Value="#D97A2C" />
      <Setter Property="BorderBrush" Value="#D97A2C" />
      <Setter Property="Foreground" Value="#1A1814" />
    </Style>
    <Style Selector="ToggleButton.modCheck:checked:pointerover">
      <Setter Property="Background" Value="#F0A455" />
      <Setter Property="BorderBrush" Value="#F0A455" />
      <Setter Property="Foreground" Value="#1A1814" />
    </Style>
    <Style Selector="CheckBox /template/ Border">
      <Setter Property="Background" Value="#15110D" />
      <Setter Property="BorderBrush" Value="#3A342C" />
      <Setter Property="CornerRadius" Value="3" />
    </Style>
    <Style Selector="CheckBox:checked /template/ Border">
      <Setter Property="Background" Value="#D97A2C" />
      <Setter Property="BorderBrush" Value="#D97A2C" />
    </Style>
    <Style Selector="Border.row">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="#221D18" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="Padding" Value="18,8" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
    <Style Selector="Border.selectedRow">
      <Setter Property="Background" Value="#221D18" />
      <Setter Property="BorderBrush" Value="#221D18" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="Padding" Value="18,8" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
    <Style Selector="ListBox">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="ListBoxItem">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,0,0,1" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>
    <Style Selector="ListBoxItem /template/ ContentPresenter">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
      <Setter Property="Background" Value="#221D18" />
    </Style>
    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#221D18" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="48,*">
    <Border Grid.Row="0" Background="#15110D" BorderBrush="#221D18" BorderThickness="0,0,0,1" Padding="14,8">
      <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto" ColumnSpacing="12" VerticalAlignment="Center">
        <Border Width="24" Height="24" CornerRadius="4" Background="#D97A2C" BorderBrush="#B86620" BorderThickness="1">
          <TextBlock Text="F" Foreground="#1A0E05" FontWeight="Bold" FontFamily="Consolas, Cascadia Mono, monospace" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
        <TextBlock Grid.Column="1" Text="Factorio Launcher" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" />
        <Button Grid.Column="2"
                Classes="iconButton"
                Command="{Binding RefreshCommand}"
                ToolTip.Tip="Reload displayed mods folder from disk">
          <Viewbox Width="16" Height="16">
            <Path Fill="#E8DFCF"
                  Data="M12,4 C9.7,4 7.7,5 6.3,6.6 L4.8,5.1 L4.8,10 L9.7,10 L7.7,8 C8.8,6.8 10.3,6 12,6 C15.3,6 18,8.7 18,12 C18,15.3 15.3,18 12,18 C9.4,18 7.2,16.3 6.4,14 L4.3,14 C5.2,17.4 8.3,20 12,20 C16.4,20 20,16.4 20,12 C20,7.6 16.4,4 12,4 Z" />
          </Viewbox>
        </Button>
        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="0" VerticalAlignment="Center">
          <Button Classes="tabActive" Command="{Binding ShowListsCommand}" IsVisible="{Binding IsListsTabActive}">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="Lists" Foreground="#F0A455" FontWeight="Medium" />
              <Border Background="#221D18" CornerRadius="3" Padding="5,1">
                <TextBlock Text="{Binding ModListCount}" Classes="dim" FontSize="10" />
              </Border>
            </StackPanel>
          </Button>
          <Button Classes="tab" Command="{Binding ShowListsCommand}" IsVisible="{Binding IsListsTabInactive}">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="Lists" Foreground="#8A7D65" FontWeight="Medium" />
              <Border Background="#221D18" CornerRadius="3" Padding="5,1">
                <TextBlock Text="{Binding ModListCount}" Classes="dim" FontSize="10" />
              </Border>
            </StackPanel>
          </Button>
          <Button Classes="tabActive" Command="{Binding ShowModsCommand}" IsVisible="{Binding IsModsTabActive}">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="Mods" Foreground="#F0A455" FontWeight="Medium" />
              <Border Background="#221D18" CornerRadius="3" Padding="5,1">
                <TextBlock Text="{Binding AvailableModCount}" Classes="dim" FontSize="10" />
              </Border>
            </StackPanel>
          </Button>
          <Button Classes="tab" Command="{Binding ShowModsCommand}" IsVisible="{Binding IsModsTabInactive}">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="Mods" Foreground="#8A7D65" FontWeight="Medium" />
              <Border Background="#221D18" CornerRadius="3" Padding="5,1">
                <TextBlock Text="{Binding AvailableModCount}" Classes="dim" FontSize="10" />
              </Border>
            </StackPanel>
          </Button>
          <Button Classes="tabActive" Command="{Binding ShowExploreCommand}" IsVisible="{Binding IsExploreTabActive}">
            <TextBlock Text="Explore" Foreground="#F0A455" FontWeight="Medium" />
          </Button>
          <Button Classes="tab" Command="{Binding ShowExploreCommand}" IsVisible="{Binding IsExploreTabInactive}">
            <TextBlock Text="Explore" Foreground="#8A7D65" FontWeight="Medium" />
          </Button>
          <Button Classes="tabActive" Command="{Binding ShowSettingsCommand}" IsVisible="{Binding IsSettingsTabActive}">
            <TextBlock Text="Settings" Foreground="#F0A455" FontWeight="Medium" />
          </Button>
          <Button Classes="tab" Command="{Binding ShowSettingsCommand}" IsVisible="{Binding IsSettingsTabInactive}">
            <TextBlock Text="Settings" Foreground="#8A7D65" FontWeight="Medium" />
          </Button>
        </StackPanel>

        <Button Grid.Column="5"
                Classes="activeBadge"
                Command="{Binding SelectActiveListCommand}"
                IsVisible="{Binding HasActiveList}"
                ToolTip.Tip="Open active mod list">
          <StackPanel Orientation="Horizontal" Spacing="7">
            <Ellipse Width="7" Height="7" Fill="#5FA84A" VerticalAlignment="Center" />
            <TextBlock Text="{Binding ActiveListName}" Foreground="#5FA84A" FontWeight="SemiBold" FontSize="12" />
          </StackPanel>
        </Button>
        <Button Grid.Column="6"
                Classes="primary"
                Content="Play"
                Command="{Binding LaunchFactorioCommand}"
                IsEnabled="{Binding CanLaunchFactorio}"
                ToolTip.Tip="{Binding LaunchFactorioToolTip}" />
      </Grid>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="Auto,*">
      <Border Grid.Column="0" Width="270" BorderBrush="#221D18" BorderThickness="0,0,1,0"
              IsVisible="{Binding IsListsTabActive}">
        <Grid RowDefinitions="Auto,*" Background="#1A1814">
          <StackPanel Grid.Row="0" Margin="12,10,12,8" Spacing="8">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="7">
              <TextBox Watermark="Filter..." Text="{Binding ListSearchText, Mode=TwoWay}" />
              <Button Grid.Column="1" Classes="primary" Content="+ New" Command="{Binding CreateModListCommand}" />
            </Grid>
            <TextBlock Classes="header" Text="{Binding VisibleModListCount, StringFormat='MOD LISTS - {0}'}" />
          </StackPanel>

          <Grid Grid.Row="1">
            <ListBox x:Name="ModListsBox"
                     ItemsSource="{Binding ModLists}"
                     SelectedItem="{Binding SelectedModList}"
                     Padding="6,0,6,8">
              <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel />
                </ItemsPanelTemplate>
              </ListBox.ItemsPanel>
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Border BorderBrush="#221D18"
                          BorderThickness="0,0,0,1"
                          Opacity="{Binding RowOpacity}">
                    <Border Padding="8,7"
                            Background="{Binding RowBackground}"
                            BorderBrush="{Binding RowBorderBrush}"
                            BorderThickness="{Binding RowBorderThickness}"
                            CornerRadius="4"
                            Tag="ModListRow"
                            PointerPressed="ModListItem_PointerPressed">
                      <Grid ColumnDefinitions="2,*" ColumnSpacing="6">
                        <Border Width="2" CornerRadius="1" Background="#5FA84A" IsVisible="{Binding IsActive}" />
                        <Grid Grid.Column="1" RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="2">
                          <TextBlock Text="{Binding Name}" Foreground="{Binding NameForeground}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <Ellipse Width="5" Height="5" Fill="#5FA84A" IsVisible="{Binding IsActive}" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding ModCount}" Classes="mono" />
                          </StackPanel>
                          <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding Description}" Classes="dim" TextTrimming="CharacterEllipsis" />
                        </Grid>
                      </Grid>
                    </Border>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>

            <Canvas x:Name="ModListDragOverlay"
                    IsHitTestVisible="False"
                    ClipToBounds="False">
              <Border x:Name="ModListDragGhost"
                      IsVisible="False"
                      ClipToBounds="False"
                      Background="#2A241D"
                      BorderBrush="#F0A455"
                      BorderThickness="1"
                      CornerRadius="6"
                      RenderTransformOrigin="50%,50%">
                <Border.RenderTransform>
                  <TransformGroup>
                    <RotateTransform Angle="-1.4" />
                    <ScaleTransform ScaleX="1.03" ScaleY="1.03" />
                  </TransformGroup>
                </Border.RenderTransform>
                <Border.Effect>
                  <DropShadowEffect BlurRadius="22" Color="#000000" Opacity="0.55" OffsetX="0" OffsetY="8" />
                </Border.Effect>
                <Image x:Name="ModListDragGhostImage" Stretch="Fill" />
              </Border>
            </Canvas>
          </Grid>
        </Grid>
      </Border>

      <!-- Explore filter sidebar -->
      <Border Grid.Column="0" Width="200" BorderBrush="#221D18" BorderThickness="0,0,1,0"
              IsVisible="{Binding IsExploreTabActive}" Background="#1A1814">
        <ScrollViewer>
          <StackPanel Margin="14,14" Spacing="18">

            <StackPanel Spacing="8">
              <TextBlock Text="CATEGORY" Classes="header" />
              <ItemsControl ItemsSource="{Binding PortalCategories}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <CheckBox Content="{Binding Label}"
                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                              Margin="0,2" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>

          </StackPanel>
        </ScrollViewer>
      </Border>

      <Grid Grid.Column="1" Background="#1A1814">
        <Grid IsVisible="{Binding IsListsTabActive}" RowDefinitions="Auto,Auto,Auto,*">
          <Border Grid.Row="0" BorderBrush="#221D18" BorderThickness="0,0,0,1" Padding="18,12">
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="7" ColumnSpacing="12">
              <StackPanel Grid.RowSpan="3" IsVisible="{Binding IsNormalMode}" Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="{Binding SelectedListName}" FontSize="18" FontWeight="SemiBold" />
                  <Border Background="#15201A" BorderBrush="#2A4A30" BorderThickness="1" CornerRadius="4" Padding="7,2" IsVisible="{Binding SelectedModList.IsActive}">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                      <Ellipse Width="5" Height="5" Fill="#5FA84A" VerticalAlignment="Center" />
                      <TextBlock Text="ACTIVE" Foreground="#5FA84A" FontWeight="SemiBold" FontSize="10" />
                    </StackPanel>
                  </Border>
                </StackPanel>
                <TextBlock Text="{Binding SelectedListDescription}" Classes="muted" />
                <TextBlock Text="{Binding SelectedListSummary}" Classes="dim" />
              </StackPanel>

              <TextBox IsVisible="{Binding IsEditMode}"
                       Text="{Binding DraftName, Mode=TwoWay}"
                       FontSize="17"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Stretch" />
              <TextBox Grid.Row="1"
                       Grid.ColumnSpan="2"
                       IsVisible="{Binding IsEditMode}"
                       Text="{Binding DraftDescription, Mode=TwoWay}"
                       Watermark="Description (optional)"
                       HorizontalAlignment="Stretch" />
              <TextBlock Grid.Row="2"
                         Grid.ColumnSpan="2"
                         IsVisible="{Binding IsEditMode}"
                         Text="{Binding DraftSummaryLabel}"
                         Classes="dim" />

              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="7" VerticalAlignment="Top">
                <StackPanel Orientation="Horizontal" Spacing="7" IsVisible="{Binding IsNormalMode}">
                  <Button Content="Edit" Command="{Binding EditSelectedCommand}" ToolTip.Tip="{Binding EditSelectedToolTip}" />
                  <Button Content="Duplicate" Command="{Binding DuplicateSelectedCommand}" />
                  <Button Classes="danger" Content="Delete" Command="{Binding DeleteSelectedCommand}" />
                  <Button Classes="primary" Content="Activate" Command="{Binding ActivateSelectedCommand}" IsEnabled="{Binding CanActivateSelected}" ToolTip.Tip="{Binding ActivateSelectedToolTip}" ToolTip.ShowOnDisabled="True" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="7" IsVisible="{Binding IsEditMode}">
                  <Button Content="Import" Command="{Binding ImportCurrentToDraftCommand}" ToolTip.Tip="Overwrite list with current game mods" />
                  <Button Content="Cancel" Command="{Binding CancelEditCommand}" />
                  <Button Classes="primary" Content="Save" Command="{Binding SaveEditCommand}" />
                </StackPanel>
              </StackPanel>

              <StackPanel Grid.Column="1" Grid.Row="1" Orientation="Horizontal" Spacing="7"
                          VerticalAlignment="Top" IsVisible="{Binding IsNormalMode}">
                <ComboBox ItemsSource="{Binding ImportSourceOptions}"
                          SelectedItem="{Binding ImportSourceList, Mode=TwoWay}"
                          PlaceholderText="Import mods from list…"
                          MinWidth="180">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Name}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Content="Import" Command="{Binding ImportFromListCommand}" />
              </StackPanel>
            </Grid>
          </Border>

          <Border Grid.Row="1" BorderBrush="#221D18" BorderThickness="0,1,0,1" Padding="18,8" IsVisible="{Binding IsEditMode}">
            <TextBox Watermark="Search mods..." Text="{Binding SearchText, Mode=TwoWay}" />
          </Border>

          <Border Grid.Row="2" BorderBrush="#221D18" BorderThickness="0,0,0,1">
            <Grid>
              <Grid ColumnDefinitions="*,90,120" Margin="18,7" ColumnSpacing="12" IsVisible="{Binding IsNormalMode}">
                <TextBlock Classes="header" Text="NAME" />
                <TextBlock Grid.Column="1" Classes="header" Text="SIZE" />
                <TextBlock Grid.Column="2" Classes="header" Text="VERSION" />
              </Grid>
              <Grid ColumnDefinitions="62,*,90,130" Margin="18,7" ColumnSpacing="12" IsVisible="{Binding IsEditMode}">
                <Button Classes="headerSortActive"
                        Command="{Binding SortEditorByActiveCommand}"
                        ToolTip.Tip="Sort selected mods first"
                        IsVisible="{Binding IsEditorSortedByActive}">
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="ACTIVE" Foreground="#F0A455" FontWeight="SemiBold" FontSize="10" />
                    <TextBlock Text="&#x25B2;" Foreground="#F0A455" FontSize="8" VerticalAlignment="Center" />
                  </StackPanel>
                </Button>
                <Button Classes="headerSort"
                        Command="{Binding SortEditorByActiveCommand}"
                        ToolTip.Tip="Sort selected mods first"
                        IsVisible="{Binding IsEditorNotSortedByActive}">
                  <TextBlock Text="ACTIVE" Foreground="#6A604F" FontWeight="SemiBold" FontSize="10" />
                </Button>

                <Button Grid.Column="1"
                        Classes="headerSortActive"
                        Command="{Binding SortEditorByNameCommand}"
                        ToolTip.Tip="Sort alphabetically by mod name"
                        IsVisible="{Binding IsEditorSortedByName}">
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="NAME" Foreground="#F0A455" FontWeight="SemiBold" FontSize="10" />
                    <TextBlock Text="&#x25B2;" Foreground="#F0A455" FontSize="8" VerticalAlignment="Center" />
                  </StackPanel>
                </Button>
                <Button Grid.Column="1"
                        Classes="headerSort"
                        Command="{Binding SortEditorByNameCommand}"
                        ToolTip.Tip="Sort alphabetically by mod name"
                        IsVisible="{Binding IsEditorNotSortedByName}">
                  <TextBlock Text="NAME" Foreground="#6A604F" FontWeight="SemiBold" FontSize="10" />
                </Button>

                <TextBlock Grid.Column="2" Classes="header" Text="SIZE" VerticalAlignment="Center" />
                <TextBlock Grid.Column="3" Classes="header" Text="VERSION" VerticalAlignment="Center" />
              </Grid>
            </Grid>
          </Border>

          <Grid Grid.Row="3">
            <ListBox IsVisible="{Binding IsNormalMode}" ItemsSource="{Binding SelectedMods}" BorderThickness="0" Background="Transparent">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Border Classes="row" Cursor="Hand" Opacity="{Binding RowOpacity}" PointerPressed="SelectedModRow_PointerPressed">
                    <StackPanel>
                      <Grid ColumnDefinitions="*,90,120" ColumnSpacing="12" VerticalAlignment="Center" HorizontalAlignment="Stretch">
                        <Grid ColumnDefinitions="12,*" RowDefinitions="Auto,Auto" ClipToBounds="True" HorizontalAlignment="Stretch">
                          <TextBlock Text="{Binding ExpandChevron}" Foreground="#6A604F" FontSize="10" VerticalAlignment="Top" Margin="0,2,0,0" />
                          <TextBlock Grid.Column="1" Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                          <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Subtitle}" Classes="muted" TextTrimming="CharacterEllipsis" />
                        </Grid>
                        <TextBlock Grid.Column="1" Text="{Binding Size}" Classes="mono" VerticalAlignment="Center" />
                        <Border Grid.Column="2"
                                Background="{Binding VersionBackground}"
                                BorderBrush="{Binding VersionBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="7,0"
                                Height="24"
                                MinWidth="66"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                ToolTip.Tip="{Binding VersionToolTip}">
                          <TextBlock Text="{Binding DisplayVersion}" Foreground="{Binding VersionForeground}" FontFamily="Consolas, Cascadia Mono, monospace" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                      </Grid>
                      <StackPanel IsVisible="{Binding IsExpanded}" Margin="12,8,0,2" Spacing="2">
                        <TextBlock Text="DEPENDENCIES" Classes="header" Margin="0,0,0,3" />
                        <ItemsControl ItemsSource="{Binding DependencyItems}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <TextBlock Text="{Binding Text}" Foreground="{Binding Foreground}" FontFamily="Consolas, Cascadia Mono, monospace" FontSize="11" />
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="No dependencies" Classes="dim" IsVisible="{Binding !HasDependencies}" />
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,6,0,0" IsVisible="{Binding CanRemoveFromList}">
                          <Button Content="{Binding ToggleListDisabledLabel}" Command="{Binding ToggleListDisabledCommand}" />
                          <Button Classes="danger" Content="Remove from list…" Command="{Binding RemoveCommand}" />
                        </StackPanel>
                      </StackPanel>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>

            <ListBox IsVisible="{Binding IsEditMode}" ItemsSource="{Binding EditableMods}" BorderThickness="0" Background="Transparent">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Border Classes="row" Background="{Binding RowBackground}" PointerPressed="EditableModRow_PointerPressed">
                    <StackPanel>
                      <Grid ColumnDefinitions="62,*,90,130" ColumnSpacing="12" VerticalAlignment="Center" HorizontalAlignment="Stretch">
                        <ToggleButton Classes="modCheck" IsChecked="{Binding IsSelected, Mode=TwoWay}" Content="&#x2713;" VerticalAlignment="Center" />
                        <Grid Grid.Column="1" ColumnDefinitions="12,*" RowDefinitions="Auto,Auto" ClipToBounds="True" HorizontalAlignment="Stretch">
                          <TextBlock Text="{Binding ExpandChevron}" Foreground="#6A604F" FontSize="10" VerticalAlignment="Top" Margin="0,2,0,0" />
                          <TextBlock Grid.Column="1" Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                          <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Subtitle}" Classes="muted" TextTrimming="CharacterEllipsis" />
                        </Grid>
                        <TextBlock Grid.Column="2" Text="{Binding Size}" Classes="mono" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="3" Spacing="3" VerticalAlignment="Center">
                          <ComboBox ItemsSource="{Binding AvailableVersions}"
                                    SelectedItem="{Binding SelectedVersion}"
                                    IsEnabled="{Binding IsSelected}"
                                    IsVisible="{Binding HasMultipleVersions}"
                                    Background="{Binding VersionBackground}"
                                    BorderBrush="{Binding VersionBorderBrush}"
                                    Foreground="{Binding VersionForeground}"
                                    ToolTip.Tip="{Binding VersionSelectionToolTip}" />
                          <Border Background="#221D18"
                                  BorderBrush="#3A342C"
                                  BorderThickness="1"
                                  CornerRadius="4"
                                  Padding="7,0"
                                  Height="24"
                                  MinWidth="66"
                                  HorizontalAlignment="Left"
                                  IsVisible="{Binding HasSingleVersion}">
                            <TextBlock Text="{Binding SelectedVersion}" Classes="mono" HorizontalAlignment="Center" VerticalAlignment="Center" />
                          </Border>
                        </StackPanel>
                      </Grid>
                      <StackPanel IsVisible="{Binding IsExpanded}" Margin="74,8,0,2" Spacing="2">
                        <TextBlock Text="DEPENDENCIES" Classes="header" Margin="0,0,0,3" />
                        <ItemsControl ItemsSource="{Binding DependencyItems}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <TextBlock Text="{Binding Text}" Foreground="{Binding Foreground}" FontFamily="Consolas, Cascadia Mono, monospace" FontSize="11" />
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="No dependencies" Classes="dim" IsVisible="{Binding !HasDependencies}" />
                      </StackPanel>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Grid>
        </Grid>

        <Grid IsVisible="{Binding IsModsTabActive}" RowDefinitions="Auto,Auto,*">
          <StackPanel Grid.Row="0" Margin="18,14" Spacing="4">
            <TextBlock Text="Installed Mods" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Classes="muted">
              <TextBlock.Text>
                <MultiBinding StringFormat="{}{0} mods — {1} disabled">
                  <Binding Path="AvailableModCount" />
                  <Binding Path="DisabledModCount" />
                </MultiBinding>
              </TextBlock.Text>
            </TextBlock>
          </StackPanel>
          <Border Grid.Row="1" BorderBrush="#221D18" BorderThickness="0,1,0,1">
            <Grid ColumnDefinitions="*,90,70,130" Margin="18,7" ColumnSpacing="12">
              <TextBlock Classes="header" Text="NAME" />
              <TextBlock Grid.Column="1" Classes="header" Text="SIZE" />
              <TextBlock Grid.Column="2" Classes="header" Text="DEPS" />
              <TextBlock Grid.Column="3" Classes="header" Text="VERSIONS" />
            </Grid>
          </Border>
          <ListBox Grid.Row="2" ItemsSource="{Binding InstalledMods}" BorderThickness="0" Background="Transparent">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border Classes="row" Cursor="Hand" Opacity="{Binding RowOpacity}" PointerPressed="InstalledModRow_PointerPressed">
                  <StackPanel>
                    <Grid ColumnDefinitions="*,90,70,130" ColumnSpacing="12" VerticalAlignment="Center" HorizontalAlignment="Stretch">
                      <Grid ColumnDefinitions="12,*" RowDefinitions="Auto,Auto" ClipToBounds="True" HorizontalAlignment="Stretch">
                        <TextBlock Text="{Binding ExpandChevron}" Foreground="#6A604F" FontSize="10" VerticalAlignment="Top" Margin="0,2,0,0" />
                        <TextBlock Grid.Column="1" Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Subtitle}" Classes="muted" TextTrimming="CharacterEllipsis" />
                      </Grid>
                      <TextBlock Grid.Column="1" Text="{Binding Size}" Classes="mono" VerticalAlignment="Center" />
                      <TextBlock Grid.Column="2" Text="{Binding DependencyCount}" Classes="mono" VerticalAlignment="Center" />
                      <StackPanel Grid.Column="3" Spacing="1">
                        <TextBlock Text="{Binding VersionCount}" Classes="mono" />
                        <TextBlock Text="{Binding Versions}" Classes="dim" TextTrimming="CharacterEllipsis" />
                      </StackPanel>
                    </Grid>
                    <StackPanel IsVisible="{Binding IsExpanded}" Margin="12,8,0,2" Spacing="2">
                      <TextBlock Text="DEPENDENCIES" Classes="header" Margin="0,0,0,3" />
                      <ItemsControl ItemsSource="{Binding DependencyItems}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <TextBlock Text="{Binding Text}" Foreground="{Binding Foreground}" FontFamily="Consolas, Cascadia Mono, monospace" FontSize="11" />
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                      <TextBlock Text="No dependencies" Classes="dim" IsVisible="{Binding !HasDependencies}" />
                      <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
                        <Button Content="{Binding ToggleDisabledLabel}" Command="{Binding ToggleDisabledCommand}" />
                        <Button Classes="danger" Content="Remove mod…" Command="{Binding DeleteCommand}" IsVisible="{Binding CanRemove}" />
                      </StackPanel>
                    </StackPanel>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>

        <Grid IsVisible="{Binding IsExploreTabActive}" RowDefinitions="Auto,Auto,Auto,*,Auto">

          <!-- Header: title + status -->
          <Border Grid.Row="0" BorderBrush="#221D18" BorderThickness="0,0,0,1" Padding="18,14">
            <StackPanel Spacing="4">
              <TextBlock Text="Explore Mods" FontSize="18" FontWeight="SemiBold" />
              <TextBlock Text="{Binding PortalStatusMessage}" Classes="muted" />
              <TextBlock IsVisible="{Binding MissingPortalCredentials}"
                         Classes="muted"
                         Text="Portal credentials not set — go to Settings to add them." />
            </StackPanel>
          </Border>

          <!-- Search bar -->
          <Border Grid.Row="1" BorderBrush="#221D18" BorderThickness="0,0,0,1" Padding="18,10">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
              <TextBox Text="{Binding PortalSearchText, Mode=TwoWay}"
                       Watermark="Search mods by name…"
                       IsEnabled="{Binding HasPortalCredentials}"
                       KeyDown="PortalSearchBox_KeyDown" />
              <Button Grid.Column="1"
                      Classes="primary"
                      Content="Search"
                      Command="{Binding PortalSearchCommand}" />
            </Grid>
          </Border>

          <!-- Column headers -->
          <Border Grid.Row="2" BorderBrush="#221D18" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="192,*,80,90,90" Margin="18,7" ColumnSpacing="12">
              <TextBlock Grid.Column="1" Classes="header" Text="NAME" />
              <TextBlock Grid.Column="2" Classes="header" Text="DOWNLOADS" />
              <TextBlock Grid.Column="3" Classes="header" Text="VERSION" />
              <TextBlock Grid.Column="4" Classes="header" Text="FACTORIO" />
            </Grid>
          </Border>

          <!-- Results list -->
          <ListBox Grid.Row="3" ItemsSource="{Binding PortalMods}" BorderThickness="0" Background="Transparent">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border Classes="row" Cursor="Hand" PointerPressed="PortalModRow_PointerPressed">
                  <Grid ColumnDefinitions="192,*,80,90,90" ColumnSpacing="12" VerticalAlignment="Center" HorizontalAlignment="Stretch">
                    <!-- Thumbnail with fallback to app icon -->
                    <Panel Width="180" Height="180" VerticalAlignment="Center">
                      <Image Source="avares://FactorioModManager.App/Assets/icon.ico"
                             Width="180" Height="180"
                             RenderOptions.BitmapInterpolationMode="HighQuality" />
                      <Image Source="{Binding Thumbnail}"
                             Width="180" Height="180"
                             RenderOptions.BitmapInterpolationMode="HighQuality"
                             IsVisible="{Binding Thumbnail, Converter={x:Static ObjectConverters.IsNotNull}}" />
                    </Panel>
                    <!-- Name + owner + summary -->
                    <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                      <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" />
                      <TextBlock Text="{Binding Owner}" Classes="muted" />
                      <TextBlock Text="{Binding Summary}" Classes="dim" TextWrapping="Wrap" />
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text="{Binding DownloadsLabel}" Classes="mono" VerticalAlignment="Center" />
                    <Border Grid.Column="3"
                            Background="#221D18"
                            BorderBrush="#3A342C"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="7,0"
                            Height="24"
                            MinWidth="66"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center">
                      <TextBlock Text="{Binding LatestVersion}" Classes="mono" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Grid.Column="4" Text="{Binding FactorioVersion}" Classes="mono" VerticalAlignment="Center" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <!-- Pagination footer -->
          <Border Grid.Row="4" BorderBrush="#221D18" BorderThickness="0,1,0,0" Padding="18,8">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto" ColumnSpacing="8" VerticalAlignment="Center">
              <Button Content="← Prev"
                      Command="{Binding PortalPrevPageCommand}"
                      IsEnabled="{Binding CanGoPortalPrev}" />
              <TextBlock Grid.Column="1" Text="{Binding PortalPageLabel}" Classes="muted" VerticalAlignment="Center" Margin="4,0" />
              <TextBlock Grid.Column="3" Text="{Binding PortalTotalCount, StringFormat='{}{0} total'}" Classes="dim" VerticalAlignment="Center" />
              <Button Grid.Column="4"
                      Content="Next →"
                      Command="{Binding PortalNextPageCommand}"
                      IsEnabled="{Binding CanGoPortalNext}" />
            </Grid>
          </Border>

          <!-- Error message -->
          <Border Grid.Row="3" Background="#2A1510" BorderBrush="#5A2820" BorderThickness="1" CornerRadius="5"
                  Padding="10" Margin="18" VerticalAlignment="Top" IsVisible="{Binding HasPortalError}">
            <TextBlock Text="{Binding PortalErrorMessage}" Foreground="#E89089" TextWrapping="Wrap" />
          </Border>

          <!-- Mod detail overlay — spans all rows when active -->
          <Grid Grid.RowSpan="5" IsVisible="{Binding IsPortalDetailActive}" Background="#1A1814" RowDefinitions="Auto,*">

            <!-- Header -->
            <Border Grid.Row="0" BorderBrush="#221D18" BorderThickness="0,0,0,1" Padding="14,10">
              <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" VerticalAlignment="Center">
                <Button Classes="tab" Content="← Back" Command="{Binding BackToPortalListCommand}" />
                <TextBlock Grid.Column="1" Text="{Binding PortalDetail.Title}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Grid.Column="2" Content="Install Latest" Command="{Binding StartInstallCommand}"
                        Classes="primary"
                        IsVisible="{Binding PortalDetail.CanInstall}" />
              </Grid>
            </Border>

            <!-- Loading indicator -->
            <TextBlock Grid.Row="1" Text="Loading…" Classes="muted"
                       IsVisible="{Binding IsPortalDetailLoading}"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />

            <!-- Detail error -->
            <Border Grid.Row="1" Background="#2A1510" BorderBrush="#5A2820" BorderThickness="1" CornerRadius="5"
                    Padding="10" Margin="18" VerticalAlignment="Top"
                    IsVisible="{Binding HasPortalDetailError}">
              <TextBlock Text="{Binding PortalDetailError}" Foreground="#E89089" TextWrapping="Wrap" />
            </Border>

            <!-- Content -->
            <ScrollViewer Name="PortalDetailScrollViewer" Grid.Row="1" IsVisible="{Binding PortalDetail, Converter={x:Static ObjectConverters.IsNotNull}}">
              <Grid ColumnDefinitions="220,*" Margin="18,16" ColumnSpacing="24" VerticalAlignment="Top">

                <!-- Left: thumbnail + meta -->
                <StackPanel Spacing="12" VerticalAlignment="Top">
                  <Panel Width="200" Height="200">
                    <Image Source="avares://FactorioModManager.App/Assets/icon.ico"
                           Width="200" Height="200"
                           RenderOptions.BitmapInterpolationMode="HighQuality" />
                    <Image Source="{Binding PortalDetail.Thumbnail}"
                           Width="200" Height="200"
                           RenderOptions.BitmapInterpolationMode="HighQuality"
                           IsVisible="{Binding PortalDetail.Thumbnail, Converter={x:Static ObjectConverters.IsNotNull}}" />
                  </Panel>
                  <StackPanel Spacing="4">
                    <TextBlock Text="{Binding PortalDetail.Owner}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding PortalDetail.Category}" Classes="muted" />
                    <TextBlock Text="{Binding PortalDetail.DownloadsLabel}" Classes="muted" />
                    <TextBlock Text="{Binding PortalDetail.LatestVersion}" Classes="mono" />
                  </StackPanel>

                  <!-- Releases -->
                  <StackPanel Spacing="6">
                    <TextBlock Text="RELEASES" Classes="header" />
                    <ItemsControl ItemsSource="{Binding PortalDetail.Releases}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                            <TextBlock Text="{Binding Version}" Classes="mono" />
                            <TextBlock Grid.Column="1" Text="{Binding InfoJson.FactorioVersion}" Classes="dim" />
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </StackPanel>

                <!-- Right: description -->
                <StackPanel Grid.Column="1" Spacing="10" VerticalAlignment="Top">
                  <TextBlock Text="{Binding PortalDetail.Summary}" Classes="muted" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding PortalDetail.Description}"
                             IsVisible="{Binding PortalDetail.HasDescription}"
                             TextWrapping="Wrap" />
                  <TextBlock Text="{Binding PortalDetail.Homepage}"
                             IsVisible="{Binding PortalDetail.HasHomepage}"
                             Classes="mono" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding PortalDetail.SourceUrl}"
                             IsVisible="{Binding PortalDetail.HasSourceUrl}"
                             Classes="mono" TextWrapping="Wrap" />
                </StackPanel>

              </Grid>
            </ScrollViewer>

            <!-- Install flow overlay -->
            <Grid Grid.RowSpan="2" IsVisible="{Binding IsInstallFlowActive}" Background="#CC1A1814">
              <Border Background="#211D18" BorderBrush="#3A3025" BorderThickness="1" CornerRadius="8"
                      MaxWidth="440" VerticalAlignment="Center" HorizontalAlignment="Center"
                      Padding="22,20" DataContext="{Binding InstallFlow}">
                <StackPanel Spacing="14">

                  <TextBlock FontSize="15" FontWeight="SemiBold">
                    <TextBlock.Text>
                      <MultiBinding StringFormat="Install &quot;{0}&quot;">
                        <Binding Path="ModTitle" />
                      </MultiBinding>
                    </TextBlock.Text>
                  </TextBlock>
                  <TextBlock Classes="muted">
                    <TextBlock.Text>
                      <MultiBinding StringFormat="Latest: v{0}">
                        <Binding Path="Release.Version" />
                      </MultiBinding>
                    </TextBlock.Text>
                  </TextBlock>

                  <!-- Picking state -->
                  <StackPanel IsVisible="{Binding IsPicking}" Spacing="12">
                    <TextBlock Text="INSTALL INTO" Classes="header" />

                    <ListBox ItemsSource="{Binding AvailableLists}"
                             SelectedItem="{Binding SelectedList}"
                             MaxHeight="180"
                             Background="#1A1814"
                             BorderThickness="1"
                             BorderBrush="#2A2520">
                      <ListBox.ItemTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding Name}" Margin="4,2" />
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Spacing="6">
                      <Button Content="+ New list" Command="{Binding SelectNewListCommand}" Classes="tab" HorizontalAlignment="Left" />
                      <TextBox IsVisible="{Binding IsNewList}"
                               Text="{Binding NewListName}"
                               Watermark="New list name…" />
                    </StackPanel>

                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                      <Button Grid.Column="1" Content="Cancel" Command="{Binding CancelCommand}" Classes="tab" />
                      <Button Grid.Column="2" Content="Install" Command="{Binding ConfirmCommand}" Classes="primary" />
                    </Grid>
                  </StackPanel>

                  <!-- Resolving deps state -->
                  <StackPanel IsVisible="{Binding IsResolvingDeps}" Spacing="14" HorizontalAlignment="Center">
                    <TextBlock Text="Checking dependencies…" Classes="muted" HorizontalAlignment="Center" />
                    <ProgressBar IsIndeterminate="True" Height="6" CornerRadius="3" Width="200" />
                    <Button Content="Cancel" Command="{Binding CancelCommand}" Classes="tab" HorizontalAlignment="Center" />
                  </StackPanel>

                  <!-- Reviewing deps state -->
                  <StackPanel IsVisible="{Binding IsReviewingDeps}" Spacing="12">
                    <ScrollViewer MaxHeight="320" VerticalScrollBarVisibility="Auto">
                      <StackPanel Spacing="12">
                        <TextBlock Text="MODS TO INSTALL" Classes="header" />
                        <ItemsControl ItemsSource="{Binding AllModsToInstall}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <TextBlock Text="{Binding ModName}" Margin="0,2" />
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel IsVisible="{Binding HasExpansionDeps}" Spacing="4">
                          <TextBlock Text="EXPANSION MODS (WILL BE ENABLED)" Classes="header" />
                          <ItemsControl ItemsSource="{Binding ExpansionDeps}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <TextBlock Text="{Binding}" Classes="muted" Margin="0,2" />
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>

                        <StackPanel IsVisible="{Binding HasAlreadySatisfied}" Spacing="4">
                          <TextBlock Text="ALREADY INSTALLED" Classes="header" />
                          <ItemsControl ItemsSource="{Binding AlreadySatisfied}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <TextBlock Text="{Binding}" Classes="muted" Margin="0,2" />
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>

                        <StackPanel IsVisible="{Binding HasIncompatibilities}" Spacing="4">
                          <TextBlock Text="INCOMPATIBLE MODS" Classes="header" Foreground="#C06060" />
                          <ItemsControl ItemsSource="{Binding Incompatibilities}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="#E89089" Margin="0,2" />
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                          <TextBlock Text="Installing anyway may cause issues if any of these are present in your mod setup."
                                     Classes="muted" TextWrapping="Wrap" Margin="0,2,0,0" />
                        </StackPanel>
                      </StackPanel>
                    </ScrollViewer>

                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                      <Button Grid.Column="1" Content="Cancel" Command="{Binding CancelCommand}" Classes="tab" />
                      <Button Grid.Column="2" Content="Install" Command="{Binding ProceedCommand}" Classes="primary" />
                    </Grid>
                  </StackPanel>

                  <!-- Downloading state -->
                  <StackPanel IsVisible="{Binding IsDownloading}" Spacing="14">
                    <TextBlock Text="{Binding CurrentDownloadLabel}" Classes="muted" HorizontalAlignment="Center" />
                    <ProgressBar Value="{Binding Progress}" Minimum="0" Maximum="1" Height="6" CornerRadius="3" />
                    <Button Content="Cancel" Command="{Binding CancelCommand}" Classes="tab" HorizontalAlignment="Center" />
                  </StackPanel>

                  <!-- Done state -->
                  <StackPanel IsVisible="{Binding IsDone}" Spacing="14" HorizontalAlignment="Center">
                    <TextBlock Text="Installed successfully" FontWeight="SemiBold" Foreground="#5FA84A" HorizontalAlignment="Center" />
                    <Button Content="Close" Command="{Binding CancelCommand}" Classes="tab" HorizontalAlignment="Center" />
                  </StackPanel>

                  <!-- Error state -->
                  <StackPanel IsVisible="{Binding IsError}" Spacing="12">
                    <TextBlock Text="Install failed" FontWeight="SemiBold" Foreground="#E89089" />
                    <TextBlock Text="{Binding ErrorMessage}" Classes="muted" TextWrapping="Wrap" />
                    <Button Content="Close" Command="{Binding CancelCommand}" Classes="tab" HorizontalAlignment="Left" />
                  </StackPanel>

                </StackPanel>
              </Border>
            </Grid>

          </Grid>
        </Grid>

        <!-- Settings tab -->
        <Grid IsVisible="{Binding IsSettingsTabActive}" RowDefinitions="Auto,*">
          <Border Grid.Row="0" BorderBrush="#221D18" BorderThickness="0,0,0,1" Padding="18,14">
            <TextBlock Text="Settings" FontSize="18" FontWeight="SemiBold" />
          </Border>
          <ScrollViewer Grid.Row="1">
            <StackPanel Margin="18,16" Spacing="20">

              <!-- Portal credentials -->
              <StackPanel Spacing="10">
                <TextBlock Text="MODS FOLDER" Classes="header" />
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                  <TextBox Text="{Binding ModsFolderPath, Mode=OneWay}"
                           IsReadOnly="True"
                           Watermark="No mods folder selected"
                           FontFamily="Consolas, Cascadia Mono, monospace"
                           FontSize="11" />
                  <Button Grid.Column="1" Content="Browse…" Command="{Binding BrowseFolderCommand}" />
                </Grid>
              </StackPanel>

              <!-- Factorio installation -->
              <StackPanel Spacing="10">
                <TextBlock Text="FACTORIO INSTALLATION" Classes="header" />
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                  <TextBox Text="{Binding FactorioInstallFolderPath, Mode=OneWay}"
                           IsReadOnly="True"
                           Watermark="No installation folder selected"
                           FontFamily="Consolas, Cascadia Mono, monospace"
                           FontSize="11" />
                  <Button Grid.Column="1" Content="Browse…" Command="{Binding BrowseInstallFolderCommand}" />
                </Grid>
              </StackPanel>

              <!-- Portal credentials -->
              <StackPanel Spacing="10">
                <TextBlock Text="MOD PORTAL CREDENTIALS" Classes="header" />
                <TextBlock Classes="muted" TextWrapping="Wrap"
                           Text="Required to browse and search the Factorio mod portal (mods.factorio.com). Your token is available on your profile page." />
                <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto" RowSpacing="8" ColumnSpacing="10">
                  <TextBlock Text="Username" VerticalAlignment="Center" />
                  <TextBox Grid.Column="1"
                           Text="{Binding PortalUsernameEntry, Mode=TwoWay}"
                           Watermark="factorio.com username" />
                  <TextBlock Grid.Row="1" Text="Token" VerticalAlignment="Center" />
                  <TextBox Grid.Row="1" Grid.Column="1"
                           Text="{Binding PortalTokenEntry, Mode=TwoWay}"
                           Watermark="API token"
                           PasswordChar="•" />
                </Grid>
                <Button Classes="primary" Content="Save" Command="{Binding SavePortalCredentialsCommand}" HorizontalAlignment="Left" />
              </StackPanel>

            </StackPanel>
          </ScrollViewer>
        </Grid>

        <Border Background="#2A1510" BorderBrush="#5A2820" BorderThickness="1" CornerRadius="5" Padding="10" Margin="18" VerticalAlignment="Bottom" IsVisible="{Binding HasError}">
          <TextBlock Text="{Binding ErrorMessage}" Foreground="#E89089" TextWrapping="Wrap" />
        </Border>
      </Grid>
    </Grid>
  </Grid>
</Window>
